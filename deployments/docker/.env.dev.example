# Docker hot-reload development environment

# Host ports
DEV_API_PORT=8081
DEV_FRONTEND_PORT=5173

# Backend development defaults
DEV_JWT_SECRET=dev-jwt-secret-change-me-please-1234567890
DEV_ADMIN_USER=admin
DEV_ADMIN_PASS=DevAdmin123!
DEV_LOG_LEVEL=debug
DEV_LOG_FORMAT=text

# Frontend file watching inside Docker
VITE_USE_POLLING=true
VITE_POLLING_INTERVAL=300
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=300

# Mirrors
ALPINE_MIRROR=mirrors.aliyun.com
NPM_REGISTRY=https://registry.npmmirror.com/
GO_PROXY=https://goproxy.cn|direct

# Timezone
TZ=UTC
