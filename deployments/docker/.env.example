# V Panel Docker Environment Variables
# Copy this file to .env and modify as needed

# Application version
VERSION=latest

# Server configuration
# 生产环境 (V_SERVER_MODE=release) 必须设置固定端口
# 开发/测试环境可以留空自动分配随机端口
V_SERVER_PORT=8080
V_SERVER_MODE=release

# Public URL (REQUIRED for remote agent deployment)
# ⚠️ 重要：远程部署 Agent 时必须配置为公网可访问的地址
# ❌ 错误：http://localhost:8080 或 http://127.0.0.1:8080
# ✅ 正确：http://YOUR_PUBLIC_IP:8080 或 https://panel.yourdomain.com
# 示例：
#   V_SERVER_PUBLIC_URL=http://123.45.67.89:8080
#   V_SERVER_PUBLIC_URL=https://panel.example.com
V_SERVER_PUBLIC_URL=
# 可选：覆盖系统自动推导的基础地址
V_SERVER_BASE_URL=

# Authentication - 首次启动会自动生成
# 如果使用默认值，启动时会自动生成强密码和 JWT Secret
# JWT Secret 生成方法: openssl rand -base64 48
V_JWT_SECRET=CHANGE_ME_OR_AUTO_GENERATE_ON_FIRST_START
V_ADMIN_USER=admin
# 密码要求: 至少 12 字符，包含大小写字母、数字和特殊字符
# 留空或使用默认值时会自动生成
V_ADMIN_PASS=CHANGE_ME_OR_AUTO_GENERATE_ON_FIRST_START

# Logging
V_LOG_LEVEL=info
V_LOG_FORMAT=json

# Payment gateways (optional)
# 未配置时，前端不会显示支付宝/微信
V_PAYMENT_ALIPAY_ENABLED=false
V_PAYMENT_ALIPAY_APP_ID=
V_PAYMENT_ALIPAY_PRIVATE_KEY=
V_PAYMENT_ALIPAY_PUBLIC_KEY=
# 留空时自动使用 ${V_SERVER_PUBLIC_URL}/api/payments/callback/alipay
V_PAYMENT_ALIPAY_NOTIFY_URL=
# 留空时自动使用 ${V_SERVER_PUBLIC_URL}/user/orders
V_PAYMENT_ALIPAY_RETURN_URL=
V_PAYMENT_ALIPAY_SANDBOX=false

V_PAYMENT_WECHAT_ENABLED=false
V_PAYMENT_WECHAT_APP_ID=
V_PAYMENT_WECHAT_MCH_ID=
V_PAYMENT_WECHAT_API_KEY=
# 留空时自动使用 ${V_SERVER_PUBLIC_URL}/api/payments/callback/wechat
V_PAYMENT_WECHAT_NOTIFY_URL=
V_PAYMENT_WECHAT_SANDBOX=false

# Timezone
TZ=UTC

# Build information (set during CI/CD)
BUILD_TIME=
GIT_COMMIT=
